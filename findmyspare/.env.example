# ─── FindMySpare Frontend — Environment Variables ───────────────────────────
# Copy to .env.local for local dev. Never commit .env.local.
# Production values set in Vercel dashboard → Settings → Environment Variables.
# NEXT_PUBLIC_* vars are baked at build time — redeploy after changing them.

# App canonical URL (OG metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend REST API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Socket.IO URL — same as API_URL (single-port deployment: REST + WS share one port)
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
